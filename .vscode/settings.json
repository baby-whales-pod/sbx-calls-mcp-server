{
  "workbench.iconTheme": "material-icon-theme",
  "workbench.colorTheme": "GitHub Light Monochrome Focused",
  "editor.fontSize": 14,
  "terminal.integrated.fontSize": 14,
  "editor.insertSpaces": true,
  "editor.tabSize": 4,
  "editor.detectIndentation": true,
  "files.autoSave": "afterDelay",
  "files.autoSaveDelay": 1000,
  // "editor.defaultFormatter": "esbenp.prettier-vscode",
  "editor.formatOnSave": true,
  "workbench.tree.indent": 20,
  //"workbench.activityBar.location": "top",
  "workbench.editor.showTabs": "multiple",
  "window.zoomLevel": 0.0,
  "[markdown]": {
    "editor.unicodeHighlight.ambiguousCharacters": false,
    "editor.unicodeHighlight.invisibleCharacters": false,
    "diffEditor.ignoreTrimWhitespace": false,
    "editor.fontWeight": "normal",
    "editor.fontFamily": "'Droid Sans Mono', 'monospace', monospace",
    "editor.fontSize": 14,
    "editor.wordWrap": "on",
    "editor.quickSuggestions": {
      "comments": "off",
      "strings": "off",
      "other": "off"
    }
  },
  "markdown.preview.fontSize": 14,
  "workbench.editorAssociations": {
    //"*.md": "vscode.markdown.preview.editor"
  },
  "markdown.marp.html": "all",
  "[dockerfile]": {
    "editor.fontSize": 14
  },
  "[dockercompose]": {
    "editor.fontSize": 14
  },
  "[json]": {
    "editor.fontSize": 14
  },
  "[yaml]": {
    "editor.fontSize": 14
  },
  "[go]": {
    "editor.fontSize": 14,
    "editor.defaultFormatter": "golang.go",
    "editor.codeActionsOnSave": {
      "source.organizeImports": "explicit"
    }
  },
  "go.lintTool": "golangci-lint",
  "go.lintOnSave": "package",
  "go.formatTool": "goimports",
  "go.useLanguageServer": true,
  "gopls": {
    "ui.semanticTokens": true,
    "ui.completion.usePlaceholders": true
  },
  "todohighlight.keywords": [
    {
      "text": "-dev",
      "color": "#ffffff",
      "backgroundColor": "#4503E0",
      "border": "1px solid #4503E0",
      "borderRadius": "3px",
      "isWholeLine": false
    },
    {
      "text": "dhi.io",
      "color": "#ffffff",
      "backgroundColor": "#0062FF",
      "border": "1px solid #0062FF",
      "borderRadius": "3px",
      "isWholeLine": false
    }

  ],
  "workbench.colorCustomizations": {
    "activityBar.activeBackground": "#7c0b82",
    "activityBar.background": "#7c0b82",
    "activityBar.foreground": "#e7e7e7",
    "activityBar.inactiveForeground": "#e7e7e799",
    "activityBarBadge.background": "#000000",
    "activityBarBadge.foreground": "#e7e7e7",
    "commandCenter.border": "#e7e7e799",
    "sash.hoverBorder": "#7c0b82",
    "statusBar.background": "#4f0753",
    "statusBar.foreground": "#e7e7e7",
    "statusBarItem.hoverBackground": "#7c0b82",
    "statusBarItem.remoteBackground": "#4f0753",
    "statusBarItem.remoteForeground": "#e7e7e7",
    "titleBar.activeBackground": "#4f0753",
    "titleBar.activeForeground": "#e7e7e7",
    "titleBar.inactiveBackground": "#4f075399",
    "titleBar.inactiveForeground": "#e7e7e799"
  },
  "peacock.color": "#4f0753"
}